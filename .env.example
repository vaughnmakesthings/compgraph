# === Supabase ===
# Database password (URLs are constructed in config.py with proper encoding)
# Use 1Password CLI: op read "op://DEV/SUPABASE_COMPGRAPH_DBPW/password"
DATABASE_PASSWORD=your-supabase-db-password

# Supabase client
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# === Supabase Auth (SEC-01) ===
# JWT secret for verifying Supabase-issued access tokens (HS256)
# Get from: Supabase Dashboard > Project Settings > API > JWT Settings
SUPABASE_JWT_SECRET=your-jwt-secret
# Service role key — bypasses RLS, used by background jobs (scrape/enrich/aggregate)
# Get from: Supabase Dashboard > Project Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Set to true ONLY in test environments to bypass auth middleware
AUTH_DISABLED=false

# === Postmark (auth emails via Supabase SMTP) ===
# Server API token — used as both SMTP user and password
# Get from: Postmark > Servers > CompGraph > API Tokens
POSTMARK_TOKEN=your-postmark-server-token

# === Anthropic ===
# Use 1Password CLI: op read "op://DEV/ANTHROPIC_API_KEY/credential"
ANTHROPIC_API_KEY=sk-ant-your-key-here

# === App Config ===
ENVIRONMENT=dev
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=*
