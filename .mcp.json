{
  "mcpServers": {
    "supabase": {
      "type": "stdio",
      "command": "op",
      "args": [
        "run",
        "--no-masking",
        "--",
        "npx",
        "-y",
        "@supabase/mcp-server@latest",
        "--access-token",
        "$SUPABASE_ACCESS_TOKEN"
      ],
      "env": {
        "SUPABASE_ACCESS_TOKEN": "op://DEV/SUPABASE_ACCESS_TOKEN/credential"
      }
    }
  }
}
