{
  "mcpServers": {
    "supabase": {
      "type": "stdio",
      "command": "op",
      "args": ["run", "--env-file=.env", "--no-masking", "--", "npx", "-y", "@supabase/mcp-server-supabase@latest"],
      "env": {
        "SUPABASE_ACCESS_TOKEN": "op://DEV/SUPABASE_ACCESS_TOKEN/credential"
      }
    },
    "codesight": {
      "type": "stdio",
      "command": "op",
      "args": ["run", "--env-file=.env", "--no-masking", "--", "uv", "run", "--project", "/Users/vmud/Documents/dev/projects/codesight", "python", "-m", "codesight"],
      "env": {
        "OPENAI_API_KEY": "op://DEV/OPENAI_API_KEY/credential"
      }
    },
    "modelcontextprotocol-servers-git": {
      "type": "stdio",
      "command": "python",
      "args": ["-m", "mcp_server_git"]
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    },
    "sentry": {
      "url": "https://mcp.sentry.dev/mcp"
    }
  }
}
